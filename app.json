{
  "expo": {
    "name": "English Tech Practice",
    "slug": "english-tech-practice",
    "version": "1.0.0",
    "scheme": "englishtech",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e27"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.fabian.englishtechpractice"
    },
    "android": {
      "package": "com.fabian.englishtechpractice",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "NETWORK"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0e27"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    }
  }
}
